<div class="max-w-md mx-auto bg-white shadow rounded-lg p-6">
  <%= form_with(model: [:admin, category], class: "space-y-4") do |form| %>
    <% if category.errors.any? %>
      <div class="bg-red-50 text-red-600 p-4 rounded">
        <ul>
          <% category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div>
      <%= form.label :parent_id, "Parent Category", class: "block text-sm font-medium text-gray-700" %>
      <%= form.collection_select :parent_id, Category.where.not(id: category.id), :id, :name, { prompt: "None" }, { class: "mt-1 block w-full p-2 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" } %>
    </div>

    <!-- Category Image -->
    <div data-controller="image-preview">
      <%= form.label :image, "Category Image", class: "block text-sm font-medium text-gray-700 mb-2" %>
      
      <div 
        class="border-2 border-dashed border-gray-300 rounded-lg p-6 flex flex-col items-center justify-center text-center hover:bg-gray-50 transition-colors cursor-pointer"
        data-action="click->image-preview#triggerInput"
      >
        <svg class="mx-auto h-8 w-8 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
          <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <p class="mt-2 text-sm text-gray-600">Click to upload image</p>
        <p class="text-xs text-gray-500">PNG, JPG up to 5MB</p>
      </div>
      
      <%= form.file_field :image, class: "hidden", data: { image_preview_target: "input", action: "change->image-preview#preview" } %>
      <div data-image-preview-target="previewContainer" class="mt-3"></div>
      
      <% if category.persisted? && category.image.attached? %>
        <div class="mt-3">
          <p class="text-xs text-gray-500 mb-1">Current image:</p>
          <div class="relative inline-block">
            <%= image_tag category.image, class: "h-20 w-20 object-cover rounded border" %>
            <%= link_to admin_attachment_path(category.image), 
                 data: { turbo_method: :delete, turbo_confirm: "Delete this image?" }, 
                 class: "absolute -top-2 -right-2 bg-red-600 text-white rounded-full p-1" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="flex justify-end space-x-3 pt-4">
      <%= link_to "Cancel", admin_categories_path, class: "px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= form.submit class: "px-4 py-2 bg-blue-600 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700" %>
    </div>
  <% end %>
</div>
