<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Variants for <%= @product.name %></h1>
    <div>
        <%= link_to "Back to Product", admin_product_path(@product), class: "mr-4 text-gray-600 hover:text-gray-900" %>
        <%= link_to "New Variant", new_admin_product_variant_path(@product), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    </div>
  </div>

  <!-- Visual Option Types Settings -->
  <% if @product.option_types.any? %>
    <div class="bg-white shadow rounded-lg p-4 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-2">📸 Visual Option Types</h3>
      <p class="text-xs text-gray-500 mb-4">
        Select which option types change the product image. For example, "Color" usually changes the image, but "Size" typically doesn't.
      </p>
      
      <%= form_with url: update_visual_settings_admin_product_variants_path(@product), method: :patch, class: "flex flex-wrap gap-4 items-center" do |f| %>
        <% @product.product_option_types.each do |pot| %>
          <label class="flex items-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50 <%= pot.is_visual ? 'border-amber-400 bg-amber-50' : 'border-gray-200' %>">
            <%= check_box_tag "visual_option_type_ids[]", pot.option_type_id, pot.is_visual, 
                class: "rounded border-gray-300 text-amber-500 focus:ring-amber-400" %>
            <span class="ml-2 text-sm font-medium text-gray-700"><%= pot.option_type.presentation %></span>
            <span class="ml-1 text-xs">📸</span>
          </label>
        <% end %>
        <%= hidden_field_tag "visual_option_type_ids[]", "" %>
        <%= f.submit "Save Visual Settings", class: "ml-4 px-4 py-2 bg-amber-500 text-white rounded hover:bg-amber-600 text-sm cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <!-- Image Sets Section - Upload images per visual option value -->
  <% visual_option_types = @product.product_option_types.where(is_visual: true).map(&:option_type) %>
  <% if visual_option_types.any? %>
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-2">🖼️ Image Sets</h3>
      <p class="text-xs text-gray-500 mb-4">
        Upload images for each <strong><%= visual_option_types.map(&:presentation).join(", ") %></strong> value. 
        All variants with the same value will share these images.
      </p>
      
      <!-- Search Filter -->
      <div class="mb-4">
        <div class="relative">
          <input type="text" 
                 id="image-set-search" 
                 placeholder="🔍 Search colors/options..." 
                 class="w-full md:w-80 px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-sm"
                 oninput="filterImageSets(this.value)">
          <svg class="absolute left-3 top-2.5 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
          </svg>
        </div>
        <p class="text-xs text-gray-400 mt-1">Type to filter option values</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-96 overflow-y-auto pr-2" id="image-sets-grid">
        <% visual_option_types.each do |ot| %>
          <% ot.option_values.each do |ov| %>
            <% image_set = @product.variant_image_sets.find_by(option_value_ids_key: ov.id.to_s) %>
            <div class="image-set-card border-2 rounded-lg p-4 bg-white hover:border-indigo-300 transition-colors" 
                 data-option-name="<%= "#{ot.presentation} #{ov.presentation}".downcase %>"
              <!-- Header -->
              <div class="flex items-center justify-between mb-4">
                <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold bg-indigo-100 text-indigo-800">
                  <%= ot.presentation %>: <%= ov.presentation %>
                </span>
                <% if image_set&.images&.attached? %>
                  <span class="text-xs font-medium text-green-600 bg-green-50 px-2 py-1 rounded"><%= image_set.images.count %> images</span>
                <% else %>
                  <span class="text-xs text-gray-400">No images</span>
                <% end %>
              </div>
              
              <!-- Existing Images Grid -->
              <% if image_set&.images&.attached? %>
                <div class="grid grid-cols-4 gap-2 mb-4">
                  <% image_set.images.each do |image| %>
                    <div class="relative group">
                      <%= image_tag image, class: "h-20 w-20 object-cover rounded-lg border-2 border-gray-200" %>
                      <%= link_to admin_attachment_path(image), 
                           data: { turbo_method: :delete, turbo_confirm: "Delete this image?" }, 
                           class: "absolute -top-2 -right-2 bg-red-600 text-white rounded-full p-1 shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-200 hover:bg-red-700" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
              
              <!-- Upload Form with Drag-Drop Style -->
              <%= form_with url: admin_product_variant_image_sets_path(@product), method: :post, local: true, multipart: true, data: { controller: "image-preview" } do |f| %>
                <%= hidden_field_tag :option_value_id, ov.id %>
                
                <label class="block cursor-pointer">
                  <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-indigo-400 hover:bg-indigo-50 transition-all duration-200">
                    <svg class="mx-auto h-8 w-8 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                      <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <p class="mt-2 text-sm text-gray-600">Click to add images</p>
                    <p class="text-xs text-gray-400">PNG, JPG up to 10MB</p>
                  </div>
                  <%= file_field_tag :images, multiple: true, class: "hidden", onchange: "this.form.submit()" %>
                </label>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <div class="mt-4 p-3 bg-blue-50 border border-blue-200 rounded-lg">
        <p class="text-sm text-blue-800">
          💡 <strong>Tip:</strong> Images uploaded here are shared by all variants with the same option value.
          Example: Upload Red t-shirt images once → Small Red, Medium Red, Large Red all use those images!
        </p>
      </div>
      
      <script>
        function filterImageSets(query) {
          const cards = document.querySelectorAll('.image-set-card');
          const searchTerm = query.toLowerCase().trim();
          let visibleCount = 0;
          
          cards.forEach(card => {
            const optionName = card.dataset.optionName || '';
            if (searchTerm === '' || optionName.includes(searchTerm)) {
              card.style.display = '';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          });
          
          // Show "no results" message if needed
          const grid = document.getElementById('image-sets-grid');
          let noResults = document.getElementById('no-results-message');
          if (visibleCount === 0 && searchTerm !== '') {
            if (!noResults) {
              noResults = document.createElement('p');
              noResults.id = 'no-results-message';
              noResults.className = 'col-span-2 text-center text-gray-500 py-8';
              noResults.textContent = 'No matching options found. Try a different search term.';
              grid.appendChild(noResults);
            }
          } else if (noResults) {
            noResults.remove();
          }
        }
      </script>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SKU</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Options</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Master</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @variants.each do |variant| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= variant.sku %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% variant.option_values.each do |ov| %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800"><%= ov.presentation %></span>
                <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(variant.price) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.stock_quantity %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.is_master ? "Yes" : "No" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "Edit", edit_admin_product_variant_path(@product, variant), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
              <%= link_to "Delete", admin_product_variant_path(@product, variant), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
