<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Variants for <%= @product.name %></h1>
    <div>
        <%= link_to "Back to Product", admin_product_path(@product), class: "mr-4 text-gray-600 hover:text-gray-900" %>
        <%= link_to "New Variant", new_admin_product_variant_path(@product), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    </div>
  </div>

  <!-- 1. Visual Option Types Settings -->
  <% if @product.option_types.any? %>
    <div class="bg-white shadow rounded-lg p-4 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-2">📸 Visual Option Types</h3>
      <p class="text-xs text-gray-500 mb-4">
        Select which option types change the product image (e.g. Color, Style).
      </p>
      
      <%= form_with url: update_visual_settings_admin_product_variants_path(@product), method: :patch, class: "flex flex-wrap gap-4 items-center" do |f| %>
        <% @product.product_option_types.each do |pot| %>
          <label class="flex items-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50 <%= pot.is_visual ? 'border-amber-400 bg-amber-50' : 'border-gray-200' %>">
            <%= check_box_tag "visual_option_type_ids[]", pot.option_type_id, pot.is_visual, 
                class: "rounded border-gray-300 text-amber-500 focus:ring-amber-400" %>
            <span class="ml-2 text-sm font-medium text-gray-700"><%= pot.option_type.presentation %></span>
            <span class="ml-1 text-xs">📸</span>
          </label>
        <% end %>
        <%= hidden_field_tag "visual_option_type_ids[]", "" %>
        <%= f.submit "Save Visual Settings", class: "ml-4 px-4 py-2 bg-amber-500 text-white rounded hover:bg-amber-600 text-sm cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <!-- 2. Smart Bulk Image Upload -->
  <% visual_pots = @product.product_option_types.where(is_visual: true) %>
  <% if visual_pots.any? %>
    <div class="bg-white shadow rounded-lg p-6 mb-6">
      <h3 class="text-lg font-medium text-gray-900 mb-2">🖼️ Smart Bulk Image Assignment</h3>
      <p class="text-xs text-gray-500 mb-4">
        Upload images for these visual combinations. We will automatically attach them to <strong>ALL standard variants</strong> that match the combination.
      </p>

      <% 
        visual_ot_ids = visual_pots.pluck(:option_type_id)
        visual_ovs = OptionValue.joins(:variants).where(variants: { product_id: @product.id }, option_type_id: visual_ot_ids).distinct
        grouped = visual_ovs.group_by(&:option_type_id).values
        combinations = grouped.empty? ? [] : grouped.first.product(*grouped.drop(1))
      %>

      <% if combinations.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <% combinations.each do |combo| %>
             <% key = combo.map(&:id).sort.join('-') %>
             <% heading = combo.map(&:presentation).join(' + ') %>
             <% matching_variants_count = @variants.select { |v| (combo.map(&:id) - v.option_value_ids).empty? }.count %>
             
             <div class="border-2 rounded-lg p-4 bg-white hover:border-indigo-300 transition-colors">
                <div class="flex items-center justify-between mb-4">
                  <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold bg-indigo-100 text-indigo-800">
                    <%= heading %>
                  </span>
                  <span class="text-xs text-gray-500"><%= matching_variants_count %> matching variants</span>
                </div>
                
                <%= form_with url: bulk_update_images_admin_product_variants_path(@product), method: :post, local: true, multipart: true do |f| %>
                  <%= hidden_field_tag :option_value_ids_key, key %>
                  <label class="block cursor-pointer">
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-indigo-400 hover:bg-indigo-50 transition-all duration-200">
                      <svg class="mx-auto h-8 w-8 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                        <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      <p class="mt-2 text-sm text-gray-600">Assign Images to <%= heading %></p>
                      <p class="text-xs text-gray-400">PNG, JPG up to 10MB</p>
                    </div>
                    <%= file_field_tag :images, multiple: true, class: "hidden", onchange: "this.form.submit()" %>
                  </label>
                <% end %>
             </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 italic">No variants match these visual option types yet.</p>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SKU</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Options</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stock</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Master</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Images</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @variants.each do |variant| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= variant.sku %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <% variant.option_values.each do |ov| %>
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800"><%= ov.presentation %></span>
                <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(variant.price) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.stock_quantity %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= variant.is_master ? "Yes" : "No" %></td>
            <td class="px-6 py-4 text-sm text-gray-500">
               <% if variant.images.attached? %>
                 <div class="flex flex-wrap gap-1 mb-2">
                   <% variant.images.each do |image| %>
                     <%= image_tag image, class: "h-10 w-10 object-cover rounded border shadow-sm" %>
                   <% end %>
                 </div>
               <% else %>
                 <span class="text-xs text-gray-400 block mb-2">No images</span>
               <% end %>
               <%= form_with model: [:admin, @product, variant], local: true, multipart: true, class: "mt-1" do |f| %>
                  <label class="cursor-pointer inline-flex items-center bg-gray-50 hover:bg-gray-100 border border-gray-300 rounded px-2 py-1 text-xs font-medium text-gray-700 transition-colors shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 mr-1 text-gray-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                    Upload Images
                    <%= f.file_field :images, multiple: true, class: "hidden", onchange: "this.form.submit()" %>
                  </label>
               <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
              <%= link_to "Edit", edit_admin_product_variant_path(@product, variant), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
              <%= link_to "Delete", admin_product_variant_path(@product, variant), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
