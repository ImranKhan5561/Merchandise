<div class="container mx-auto px-4 py-8">
  <div class="mb-6 flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold flex items-center text-gray-900">
        <%= link_to "Orders", admin_orders_path, class: "text-gray-500 hover:text-indigo-600 mr-2" %> / <%= @order.order_number %>
      </h1>
      <p class="text-sm text-gray-500 mt-1">Placed on <%= @order.created_at.strftime("%B %d, %Y %I:%M %p") %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column: Items & Details -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Items Table -->
      <div class="bg-white shadow rounded-lg overflow-hidden border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 border-b pb-2">Order Items</h2>
        
        <table class="w-full text-left">
          <thead>
            <tr class="text-gray-500 text-xs uppercase border-b">
              <th class="pb-3 font-medium">Product</th>
              <th class="pb-3 font-medium text-right">Price</th>
              <th class="pb-3 font-medium text-center">Qty</th>
              <th class="pb-3 font-medium text-right">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @order.order_items.each do |item| %>
              <tr class="text-sm">
                <td class="py-4">
                  <div class="flex items-center gap-4">
                    <% if item.product.images.attached? %>
                      <%= image_tag item.product.images.first, class: "h-12 w-12 object-cover rounded shadow-sm border border-gray-100" %>
                    <% else %>
                      <div class="h-12 w-12 bg-gray-50 flex items-center justify-center rounded border border-gray-100 italic text-[10px] text-gray-400">No img</div>
                    <% end %>
                    <div class="flex-1">
                      <div class="font-medium text-gray-900">
                        <%= link_to item.product_name, admin_product_path(item.product), class: "hover:text-indigo-600 truncate block" %>
                      </div>
                      <div class="flex flex-wrap gap-x-3 gap-y-1 mt-1">
                        <% if item.variant_sku.present? %>
                          <span class="text-[10px] font-mono text-gray-500 bg-gray-50 px-1.5 py-0.5 rounded border border-gray-100">SKU: <%= item.variant_sku %></span>
                        <% end %>
                        <% if item.variant.present? %>
                          <% item.variant.option_values.includes(:option_type).each do |ov| %>
                            <span class="text-[10px] text-gray-600 bg-indigo-50/50 px-1.5 py-0.5 rounded text-indigo-700 border border-indigo-100/50">
                              <span class="font-semibold uppercase tracking-tighter opacity-70"><%= ov.option_type.presentation %>:</span> <%= ov.presentation %>
                            </span>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="py-4 text-right text-gray-600"><%= number_to_currency(item.price) %></td>
                <td class="py-4 text-center text-gray-600 font-medium">x<%= item.quantity %></td>
                <td class="py-4 text-right font-semibold text-gray-900"><%= number_to_currency(item.price * item.quantity) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>

        <!-- Totals -->
        <div class="mt-4 pt-4 border-t border-gray-200">
          <div class="flex justify-between py-1 text-sm text-gray-600">
            <span>Subtotal</span>
            <span><%= number_to_currency(@order.subtotal) %></span>
          </div>
          <div class="flex justify-between py-1 text-sm text-gray-600">
            <span>Shipping Fee</span>
            <span><%= number_to_currency(@order.shipping_fee) %></span>
          </div>
          <div class="flex justify-between py-1 text-sm text-gray-600">
            <span>Tax</span>
            <span><%= number_to_currency(@order.tax) %></span>
          </div>
          <div class="flex justify-between py-2 mt-2 border-t text-base font-bold text-gray-900">
            <span>Total</span>
            <span><%= number_to_currency(@order.total_amount) %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Status & Customer -->
    <div class="space-y-6">
      
      <!-- Management Card -->
      <div class="bg-white shadow rounded-lg border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Manage Order</h2>
        
        <%= form_with model: [:admin, @order], local: true, class: "space-y-4" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fulfillment Status</label>
            <%= f.select :status, Order.statuses.keys.map { |w| [w.titleize, w] }, {}, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Payment Status</label>
            <%= f.select :payment_status, Order.payment_statuses.keys.map { |w| [w.titleize, w] }, {}, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
          </div>

          <%= f.submit "Update Order", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
        <% end %>
      </div>

      <!-- Customer Card -->
      <div class="bg-white shadow rounded-lg border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 border-b pb-2">Customer & Shipping</h2>
        
        <div class="mb-4">
          <p class="font-medium text-sm text-gray-900"><%= @order.user&.name || 'Guest User' %></p>
          <p class="text-sm text-indigo-600"><%= @order.user&.email %></p>
        </div>

        <div class="mb-6 space-y-2">
          <div class="flex items-center justify-between text-xs">
            <span class="text-gray-500 uppercase font-semibold">Payment</span>
            <span class="text-gray-900 font-medium"><%= @order.payment_method.to_s.upcase %></span>
          </div>
          <% if @order.customer_ip.present? %>
            <div class="flex items-center justify-between text-xs">
              <span class="text-gray-500 uppercase font-semibold">Customer IP</span>
              <span class="text-gray-900 font-mono bg-gray-50 px-1.5 py-0.5 rounded border border-gray-100"><%= @order.customer_ip %></span>
            </div>
          <% end %>
        </div>

        <div>
          <h3 class="text-xs font-semibold text-gray-500 uppercase mb-2">Shipping Details</h3>
          <p class="text-sm font-medium text-gray-800"><%= @order.shipping_name %></p>
          <p class="text-sm text-gray-600"><%= @order.shipping_address %></p>
          <p class="text-sm text-gray-600"><%= @order.shipping_city %>, <%= @order.shipping_state %> <%= @order.shipping_pincode %></p>
          <p class="text-sm text-gray-600"><%= @order.shipping_country %></p>
          <p class="text-sm text-gray-600 mt-1">📞 <%= @order.shipping_phone %></p>
        </div>
      </div>

    </div>
  </div>
</div>
