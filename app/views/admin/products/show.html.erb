<div class="container mx-auto px-4 py-8">
  <div class="mb-6 flex justify-between items-center">
      <h1 class="text-3xl font-bold"><%= @product.name %></h1>
      <div>
         <%= link_to "Edit", edit_admin_product_path(@product), class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 mr-2" %>
         <%= link_to "Manage Variants", admin_product_variants_path(@product), class: "bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700" %>
      </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">Product Details</h3>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Category</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @product.category&.name %></dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Base Price</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= number_to_currency(@product.base_price) %></dd>
        </div>
         <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500">Description</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @product.description %></dd>
        </div>
      </dl>
    </div>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
     <!-- Specs -->
     <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6">
             <h3 class="text-lg leading-6 font-medium text-gray-900">Specifications</h3>
        </div>
         <div class="border-t border-gray-200 px-4 py-4">
             <ul class="list-disc pl-5">
                 <% @product.product_specifications.each do |spec| %>
                     <li><strong><%= spec.name %>:</strong> <%= spec.value %></li>
                 <% end %>
             </ul>
         </div>
     </div>

     <!-- Variants Preview -->
     <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6">
             <h3 class="text-lg leading-6 font-medium text-gray-900">Variants (<%= @product.variants.count %>)</h3>
        </div>
         <div class="border-t border-gray-200 px-4 py-4">
             <% if @product.variants.any? %>
                 <ul class="space-y-2">
                     <% @product.variants.limit(5).each do |v| %>
                         <li class="flex justify-between text-sm">
                             <span><%= v.sku %></span>
                             <span class="font-bold"><%= number_to_currency(v.price) %></span>
                         </li>
                     <% end %>
                 </ul>
                 <% if @product.variants.count > 5 %>
                    <div class="mt-2 text-sm text-blue-600">And <%= @product.variants.count - 5 %> more...</div>
                 <% end %>
             <% else %>
                <p class="text-gray-500 text-sm">No variants configured.</p>
             <% end %>
         </div>
     </div>
  </div>

</div>
